{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "df-car-sale"
		},
		"LS_sink_linkedservice_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_sink_linkedservice'"
		},
		"LS_sink_linkedservice_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "carssalesdb.database.windows.net"
		},
		"LS_sink_linkedservice_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "carsales_db"
		},
		"LS_sink_linkedservice_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"ls_github_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/gundu7D/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "df-car-sale_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_sink_linkedservice_password": {
						"value": "[parameters('LS_sink_linkedservice_password')]"
					},
					"LS_sink_linkedservice_properties_typeProperties_server": {
						"value": "[parameters('LS_sink_linkedservice_properties_typeProperties_server')]"
					},
					"LS_sink_linkedservice_properties_typeProperties_database": {
						"value": "[parameters('LS_sink_linkedservice_properties_typeProperties_database')]"
					},
					"LS_sink_linkedservice_properties_typeProperties_userName": {
						"value": "[parameters('LS_sink_linkedservice_properties_typeProperties_userName')]"
					},
					"ls_github_properties_typeProperties_url": {
						"value": "[parameters('ls_github_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}